# ─── TikiTaka Jobs — Variables de Entorno ──────────────────────────────────────
# Copia este archivo como .env para uso local o configura estas variables
# directamente en Railway (Settings → Variables) para producción.
# NUNCA subas archivos .env* al repositorio (ya están en .gitignore)
#
# Cómo obtener estos valores:
#   Supabase     → Settings → API → Project URL y Service Role Key
#   API-Football → https://dashboard.api-football.com → Your Key

# URL del proyecto en Supabase
SUPABASE_URL=

# Clave de servicio de Supabase (service_role — SOLO para uso en servidor)
SUPABASE_SERVICE_KEY=

# API Key de API-Football (v3.football.api-sports.io)
API_FOOTBALL_KEY=
